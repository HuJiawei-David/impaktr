{
  "name": "impaktr-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "sudo rm -rf .next && next dev",
    "dev:with-socket": "concurrently \"npm run socket:dev\" \"next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "turbo": "sudo rm -rf .next && npm run dev",
    "turbo:clean": "sudo rm -rf .next node_modules/.cache && npm run dev",
    "dev:user": "NODE_OPTIONS='--max-old-space-size=1024' DIST_DIR=.next-$USER NEXT_CACHE_DIR=/home/$USER/.next-cache next dev -p ${PORT:-3000}",
    "start:user": "NODE_OPTIONS='--max-old-space-size=1024' DIST_DIR=.next-$USER NEXT_CACHE_DIR=/home/$USER/.next-cache next start -p ${PORT:-3000}",
    "clean:user": "rm -rf .next-$USER /home/$USER/.next-cache",
    "dev:safe": "./dev-safe.sh",
    "monitor": "./memory-monitor.sh",
    "socket:dev": "node socket-server.js",
    "socket:start": "node socket-server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@types/bcryptjs": "^2.4.6",
    "aws-sdk": "^2.1511.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.16",
    "ioredis": "^5.3.2",
    "jose": "^5.1.3",
    "lucide-react": "^0.294.0",
    "next": "^15.5.2",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.9.7",
    "puppeteer": "^24.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-query": "^3.39.3",
    "recharts": "^2.8.0",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "stripe": "^18.5.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-next": "^15.5.2",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
