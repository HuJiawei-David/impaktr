generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                     @id @default(cuid())
  email                        String                     @unique
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  emailVerified                DateTime?
  image                        String?
  name                         String?
  password                     String?
  bio                          String?
  country                      String?
  impactScore                  Float                      @default(0) @map("impact_score")
  lastActivityDate             DateTime?
  level                        Int                        @default(1)
  location                     String?
  longestStreak                Int                        @default(0)
  streak                       Int                        @default(0)
  totalPoints                  Int                        @default(0)
  xp                           Int                        @default(0)
  city                         String?
  dateOfBirth                  DateTime?
  displayName                  String?
  firstName                    String?
  gender                       String?
  isPublic                     Boolean                    @default(true)
  languages                    Json?
  lastName                     String?
  nationality                  String?
  occupation                   String?
  organization                 String?
  referralCode                 String?                    @unique
  role                         String?                    @default("USER")
  sdgFocus                     Json?
  showEmail                    Boolean                    @default(false)
  phone                        String?
  showProgress                 Boolean                    @default(true)
  allowMessages                Boolean                    @default(true)
  state                        String?
  userType                     UserType?                  @default(INDIVIDUAL)
  website                      String?
  tier                         IndividualRank             @default(HELPER)
  achievements                 Achievement[]
  activities                   Activity[]
  applications                 Application[]
  backups                      Backup[]
  restoredBackups              Backup[]                   @relation("RestoredBackups")
  broadcasts                   Broadcast[]
  certificateTemplates         CertificateTemplate[]
  challenges                   ChallengeParticipant[]
  comments                     Comment[]
  createdCommunities           Community[]                @relation("CreatedCommunities")
  communityMemberships         CommunityMember[]          @relation("CommunityMemberships")
  communityModerators          CommunityModerator[]       @relation("CommunityModerators")
  communityPosts               CommunityPost[]            @relation("CommunityPosts")
  communityPostComments        CommunityPostComment[]     @relation("CommunityPostComments")
  communityPostLikes           CommunityPostLike[]        @relation("CommunityPostLikes")
  communityPostCommentLikes    CommunityPostCommentLike[] @relation("CommunityPostCommentLikes")
  communityResources           CommunityResource[]        @relation("CommunityResources")
  donations                    Donation[]
  emailTemplates               EmailTemplate[]
  eventBookmarks               EventBookmark[]
  eventCommentLikes            EventCommentLike[]
  eventComments                EventComment[]
  eventImages                  EventImage[]
  following                    Follow[]                   @relation("Followers")
  followers                    Follow[]                   @relation("Following")
  likes                        Like[]
  receivedMessages             Message[]                  @relation("ReceivedMessages")
  sentMessages                 Message[]                  @relation("SentMessages")
  groupChatMemberships         GroupChatMember[]         @relation("GroupChatMemberships")
  groupChatMessages            GroupChatMessage[]        @relation("GroupChatMessages")
  notificationTemplates         NotificationTemplate[]
  notifications                Notification[]
  opportunityBookmarks         OpportunityBookmark[]
  sentInvitations              OrganizationInvitation[]
  sentCommunityInvitations     CommunityInvitation[]     @relation("SentCommunityInvitations")
  organizationMemberships       OrganizationMember[]
  participations               Participation[]
  departmentAccountsOwned      DepartmentAccess[]         @relation("DepartmentAccount")
  departmentAccessGrants       DepartmentAccess[]         @relation("Grantor")
  departmentAccesses           DepartmentAccess[]         @relation("IndividualUser")
  posts                        Post[]
  rateLimitViolations          RateLimitViolation[]
  rateLimits                   RateLimit[]
  referralRewards              ReferralReward[]
  referredBy                   Referral[]                 @relation("ReferredBy")
  referrals                    Referral[]
  reports                      Report[]
  saves                        Save[]
  scoreHistory                 ScoreHistory[]
  shares                       Share[]
  supportResponses             SupportResponse[]
  assignedTickets              SupportTicket[]            @relation("AssignedTickets")
  supportTickets               SupportTicket[]
  badges                       UserBadge[]
  requestedVettingRequests     VettingRequest[]           @relation("RequestedVettingRequests")
  vettingRequests              VettingRequest[]
  vettingResponses             VettingResponse[]
  volunteerProfile             VolunteerProfile?
  organizationPosts            OrganizationPost[]
  postComments                 PostComment[]
  postReactions                PostReaction[]
  commentReactions             CommentReaction[]
  connectionsRequested         Connection[]               @relation("ConnectionsRequested")
  connectionsReceived          Connection[]               @relation("ConnectionsReceived")
  userRecommendations          Recommendation[]           @relation("UserRecommendations")
  authorRecommendations        Recommendation[]           @relation("AuthorRecommendations")
  certificates                 Certificate[]
  receivedCommunityInvitations CommunityInvitation[]       @relation("ReceivedCommunityInvitations")

  @@map("users")
}

model Organization {
  id                   String                     @id @default(cuid())
  name                 String
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  stripeCustomerId     String?                    @unique
  subscriptionStatus   String?                    @default("active")
  address              String?
  averageImpactScore   Float                      @default(0)
  carbonFootprint      Float?                     @default(0)
  city                 String?
  state                String?
  companySize          String?
  country              String?
  currentPeriodEnd     DateTime?
  description          String?
  donationTotal        Float                      @default(0)
  email                String?
  employeeCount        Int?                       @default(0)
  esgScore             Float?                     @default(0)
  eventCount           Int                        @default(0)
  industry             String?
  lastReportDate       DateTime?
  logo                 String?
  maxEvents            Int                        @default(5)
  maxMembers           Int                        @default(10)
  nextTierAt           Int                        @default(1000)
  participationRate    Float                      @default(0)
  phone                String?
  reportFrequency      String?                    @default("monthly")
  sector               String?
  slug                 String?                    @unique
  stripeSubscriptionId String?                    @unique
  subscriptionTier     String                     @default("REGISTERED")
  tierPoints           Int                        @default(0)
  volunteerHours       Float                      @default(0)
  website              String?
  type                 String?
  sdgFocusAreas        Int[] // Store original SDG focus areas from registration
  tier                 OrganizationTier           @default(IMPACT_STARTER)
  campaigns            Campaign[]
  corporateBadges      CorporateBadgeEarned[]
  donations            Donation[]
  esgMetrics           ESGMetric[]
  events               Event[]
  followers            Follow[]                   @relation("OrgFollowers")
  opportunities        Opportunity[]
  activities           OrganizationActivity[]
  badges               OrganizationBadge[]
  invitations          OrganizationInvitation[]
  locations            OrganizationLocation[]
  members              OrganizationMember[]
  scoreHistory         OrganizationScoreHistory[]
  posts                Post[]
  organizationPosts    OrganizationPost[]
  vettingRequests      VettingRequest[]
  validationResults    ValidationResult[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member")
  joinedAt       DateTime     @default(now())
  invitedBy      String?
  status         String       @default("active")
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model DepartmentAccess {
  id                  String    @id @default(cuid())
  departmentAccountId String
  individualUserId    String
  grantedBy           String
  grantedAt           DateTime  @default(now())
  revokedAt           DateTime?
  permissions         Json? // Array of permission strings: ["CREATE_EVENTS", "POST_OPPORTUNITIES", "ADMIN_ACCESS"]
  updatedAt           DateTime  @updatedAt

  departmentAccount User @relation("DepartmentAccount", fields: [departmentAccountId], references: [id], onDelete: Cascade)
  individualUser    User @relation("IndividualUser", fields: [individualUserId], references: [id], onDelete: Cascade)
  grantor           User @relation("Grantor", fields: [grantedBy], references: [id], onDelete: Cascade)

  @@unique([departmentAccountId, individualUserId])
  @@index([departmentAccountId])
  @@index([individualUserId])
  @@index([revokedAt])
  @@map("department_access")
}

model OrganizationInvitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String       @default("member")
  token          String       @unique
  status         String       @default("PENDING")
  invitedBy      String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  inviter        User         @relation(fields: [invitedBy], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@index([status])
  @@map("organization_invitations")
}

model OrganizationActivity {
  id               String       @id @default(cuid())
  organizationId   String
  description      String?
  createdAt        DateTime     @default(now())
  activityType     String
  impactPoints     Int          @default(0)
  participantCount Int          @default(0)
  title            String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_activities")
}

model OrganizationBadge {
  id             String       @id @default(cuid())
  organizationId String
  earnedAt       DateTime     @default(now())
  badgeName      String
  badgeType      String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_badges")
}

model ESGMetric {
  id             String       @id @default(cuid())
  organizationId String
  category       String
  metricName     String
  value          Float
  unit           String
  period         String
  reportedAt     DateTime     @default(now())
  verifiedAt     DateTime?
  verifiedBy     String?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, category])
  @@index([period])
  @@map("esg_metrics")
}

model CorporateBadge {
  id          String                 @id @default(cuid())
  name        String                 @unique
  description String
  icon        String
  category    String
  criteria    Json
  tier        String                 @default("bronze")
  createdAt   DateTime               @default(now())
  earned      CorporateBadgeEarned[]

  @@map("corporate_badges")
}

model CorporateBadgeEarned {
  id             String         @id @default(cuid())
  organizationId String
  badgeId        String
  earnedAt       DateTime       @default(now())
  badge          CorporateBadge @relation(fields: [badgeId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, badgeId])
  @@map("corporate_badges_earned")
}

model CorporateLeaderboard {
  id        String   @id @default(cuid())
  period    String
  category  String
  rankings  Json
  updatedAt DateTime @updatedAt

  @@unique([period, category])
  @@index([period])
  @@index([category])
  @@map("corporate_leaderboards")
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  sdg         String?
  points      Int      @default(0)
  impact      Json?
  location    String?
  createdAt   DateTime @default(now())
  verified    Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([sdg])
  @@map("activities")
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  category    String
  createdAt   DateTime    @default(now())
  requirement Json
  sdgNumber   Int?
  tier        BadgeTier   @default(SUPPORTER)
  rarity      BadgeTier   @default(SUPPORTER)
  users       UserBadge[]

  @@unique([sdgNumber, tier])
  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id])
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Challenge {
  id           String                 @id @default(cuid())
  title        String
  description  String
  type         String
  sdg          String?
  startDate    DateTime
  endDate      DateTime
  goal         Json
  reward       Int                    @default(0)
  createdAt    DateTime               @default(now())
  participants ChallengeParticipant[]

  @@map("challenges")
}

model ChallengeParticipant {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  progress    Json
  completed   Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  completedAt DateTime?
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("challenge_participants")
}

model Event {
  id                    String                @id @default(cuid())
  title                 String
  description           String
  organizationId        String?
  startDate             DateTime
  endDate               DateTime
  totalHours            Float                 @default(0)
  timezone              String?
  location              String
  maxParticipants       Int?
  currentParticipants   Int                   @default(0)
  createdAt             DateTime              @default(now())
  imageUrl              String?
  organizerId           String?
  createdAsUserId       String? // Department account ID if event created via department access (audit field)
  sdg                   String?
  campaignId            String?
  isPublic              Boolean               @default(true)
  locationId            String?
  type                  EventCategory
  status                EventStatus           @default(UPCOMING)
  skills                String[]              @default([])
  intensity             Float                 @default(1.0)
  verificationType      String                @default("ORGANIZER")
  eventInstructions     String?
  materialsNeeded       String[]              @default([])
  emergencyContact      Json?
  requiresApproval      Boolean               @default(false)
  autoIssueCertificates Boolean               @default(true)
  registrationDeadline  DateTime?
  attendanceCode        String?
  attendanceEnabled     Boolean               @default(false)
  attendanceEnabledAt   DateTime?
  attendanceDisabledAt  DateTime?
  certificateConfig     Json?                 // Certificate configuration: { certificateName, certificateContent }
  broadcasts            Broadcast[]
  bookmarks             EventBookmark[]
  comments              EventComment[]
  images                EventImage[]
  certificates          Certificate[]
  campaign              Campaign?             @relation(fields: [campaignId], references: [id])
  organizationLocation  OrganizationLocation? @relation(fields: [locationId], references: [id])
  organization          Organization?         @relation(fields: [organizationId], references: [id])
  participations        Participation[]
  organizationPosts     OrganizationPost[]
  sessions              EventSession[]
  groupChat             GroupChat?

  @@index([startDate])
  @@index([type])
  @@index([isPublic])
  @@map("events")
}

model EventSession {
  id        String   @id @default(cuid())
  eventId   String
  label     String?
  startAt   DateTime
  endAt     DateTime
  breakMin  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_sessions")
}

model EventBookmark {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_bookmarks")
}

model EventComment {
  id        String             @id @default(cuid())
  eventId   String
  userId    String
  content   String
  parentId  String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  likes     EventCommentLike[]
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent    EventComment?      @relation("EventCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   EventComment[]     @relation("EventCommentReplies")
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
  @@index([parentId])
  @@map("event_comments")
}

model EventCommentLike {
  id        String       @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime     @default(now())
  comment   EventComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("event_comment_likes")
}

model EventImage {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  url       String
  caption   String?
  category  String?  @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
  @@map("event_images")
}

model OpportunityBookmark {
  id            String      @id @default(cuid())
  userId        String
  opportunityId String
  createdAt     DateTime    @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@map("opportunity_bookmarks")
}

model Post {
  id             String         @id @default(cuid())
  userId         String?
  content        String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  imageUrl       String?
  sdg            String?
  isDeleted      Boolean        @default(false)
  isPinned       Boolean        @default(false)
  location       String?
  mediaUrls      String[]       @default([])
  organizationId String?
  tags           String[]       @default([])
  type           PostType       @default(TEXT)
  visibility     PostVisibility @default(PUBLIC)
  comments       Comment[]
  likes          Like[]
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports        Report[]
  saves          Save[]
  shares         Share[]

  @@index([userId])
  @@index([organizationId])
  @@index([type])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports   Report[]

  @@index([postId])
  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("likes")
}

model Follow {
  id             String        @id @default(cuid())
  followerId     String
  followingId    String?
  createdAt      DateTime      @default(now())
  followingOrgId String?
  follower       User          @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following      User?         @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingOrg   Organization? @relation("OrgFollowers", fields: [followingOrgId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@unique([followerId, followingOrgId])
  @@map("follows")
}

model Connection {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("ConnectionsRequested", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ConnectionsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@map("connections")
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String // The user being recommended
  authorId   String // The user writing the recommendation
  authorType String // 'individual' or 'organization'
  text       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation("UserRecommendations", fields: [userId], references: [id], onDelete: Cascade)
  author     User     @relation("AuthorRecommendations", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([userId, authorId])
  @@map("recommendations")
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Share {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("shares")
}

model Save {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("saves")
}

model Report {
  id          String       @id @default(cuid())
  postId      String?
  commentId   String?
  userId      String
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  comment     Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  post        Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Opportunity {
  id             String                @id @default(cuid())
  organizationId String
  title          String
  description    String
  requirements   String[]
  spots          Int
  spotsFilled    Int                   @default(0)
  deadline       DateTime?
  applyUrl       String?
  location       String?
  isRemote       Boolean               @default(false)
  skills         String[]              @default([])
  sdg            String?
  status         OpportunityStatus     @default(OPEN)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  applications   Application[]
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookmarks      OpportunityBookmark[]

  @@index([organizationId])
  @@index([status])
  @@map("opportunities")
}

model Application {
  id            String            @id @default(cuid())
  opportunityId String
  userId        String
  status        ApplicationStatus @default(PENDING)
  message       String?
  resumeUrl     String?
  appliedAt     DateTime          @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?
  opportunity   Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, userId])
  @@map("applications")
}

model Message {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  type       MessageType @default(TEXT)
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())
  receiver   User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model GroupChat {
  id          String            @id @default(cuid())
  eventId     String            @unique
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members     GroupChatMember[]
  messages    GroupChatMessage[]

  @@index([eventId])
  @@map("group_chats")
}

model GroupChatMember {
  id          String    @id @default(cuid())
  groupChatId String
  userId      String
  role        String    @default("MEMBER") // MEMBER, ADMIN
  joinedAt    DateTime  @default(now())
  groupChat   GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
  user        User      @relation("GroupChatMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupChatId, userId])
  @@index([userId])
  @@index([groupChatId])
  @@map("group_chat_members")
}

model GroupChatMessage {
  id         String      @id @default(cuid())
  groupChatId String
  senderId   String
  content    String
  type       MessageType @default(TEXT)
  createdAt  DateTime    @default(now())
  groupChat  GroupChat   @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
