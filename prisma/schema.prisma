model OrganizationPost {
  id             String               @id @default(cuid())
  organizationId String
  authorId       String // User who posted (org admin)
  content        String               @db.Text
  postType       OrganizationPostType // UPDATE, EVENT_ANNOUNCE, EVENT_RECAP, IMPACT_STORY, ACHIEVEMENT

  // Media
  images    String[] // Array of image URLs
  videos    String[] // Video URLs/embeds
  documents Json? // Document attachments

  // Metadata
  eventId  String?
  location String?
  sdgs     Int[]
  tags     String[]

  // Impact Metrics
  hoursReported   Float?
  peopleReached   Int?
  volunteersCount Int?

  // Interactions
  likes  Int @default(0)
  shares Int @default(0)
  kudos  Int @default(0)

  // Settings
  visibility   Visibility // PUBLIC, FOLLOWERS, MEMBERS
  isPinned     Boolean    @default(false)
  scheduledFor DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event        Event?         @relation(fields: [eventId], references: [id])
  comments     PostComment[]
  reactions    PostReaction[]

  @@map("organization_posts")
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  parentId  String? // For nested replies
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      OrganizationPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    PostComment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies   PostComment[]     @relation("CommentReplies")
  reactions CommentReaction[]

  @@map("post_comments")
}

model PostReaction {
  id        String       @id @default(cuid())
  postId    String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  post OrganizationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_reactions")
}

model CommentReaction {
  id        String       @id @default(cuid())
  commentId String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_reactions")
}

enum OrganizationPostType {
  UPDATE
  EVENT_ANNOUNCE
  EVENT_RECAP
  IMPACT_STORY
  ACHIEVEMENT
  MILESTONE
  PARTNERSHIP
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  MEMBERS
  PRIVATE
}

enum ReactionType {
  LIKE
  LOVE
  INSPIRE
  SUPPORT
  KUDOS
}

model ValidationResult {
  id               String       @id @default(cuid())
  organizationId   String
  validatedBy      String
  validationScore  Int // 0-100 score
  isValid          Boolean
  issues           Json // Array of ValidationIssue objects
  recommendations  String[] // Array of recommendation strings
  validatorResults Json // Array of ValidationResult objects from each validator
  validatedAt      DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("validation_results")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Country {
  id        String   @id @default(cuid())
  code      String   @unique // ISO 3166-1 alpha-2 (e.g., "US", "MY")
  name      String
  code3     String?  // ISO 3166-1 alpha-3 (e.g., "USA", "MYS")
  numeric   String?  // ISO 3166-1 numeric (e.g., "840", "458")
  states    State[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@map("countries")
}

model State {
  id        String   @id @default(cuid())
  code      String   // State/Province code (e.g., "CA", "NY", "KL")
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, code])
  @@index([countryId])
  @@index([name])
  @@map("states")
}